# Название приложения
APP_NAME='SHM Client'

# Telegram Login Widget - имя бота (без @)
TELEGRAM_BOT_NAME=your_bot_name
TELEGRAM_BOT_AUTH_ENABLE=false

# Telegram WebApp авторизация - кнопка "Войти через Telegram"
TELEGRAM_WEBAPP_AUTH_ENABLE=false
TELEGRAM_WEBAPP_PROFILE=''

# Ссылка на поддержку
SUPPORT_LINK='https://t.me/your_support_bot'

OTP_ENABLE=true
PASSKEY_ENABLE=true